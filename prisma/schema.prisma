// Prisom Project Panel — Production Schema
// Core workflow: code is pushed to GitHub → GitHub App webhook notifies Prisom
// → dashboard syncs repo/project data → manages files, commits, preview, logs,
//   databases, domains, publishing, and AI prompt actions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectType {
  APP
  API
  LIBRARY
  STATIC
  SERVICE
  OTHER
}

enum ProjectStatus {
  ACTIVE
  BUILDING
  ERROR
  ARCHIVED
  DRAFT
}

enum Visibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum GitSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum GitSyncSource {
  WEBHOOK
  MANUAL
  SCHEDULED
}

enum FileType {
  FILE
  DIRECTORY
  SYMLINK
}

enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskSource {
  MANUAL
  AI
  GITHUB
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EnvironmentName {
  DEVELOPMENT
  PREVIEW
  PRODUCTION
}

enum EnvironmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum SslStatus {
  NONE
  PENDING
  ACTIVE
  FAILED
  EXPIRED
}

enum DatabaseType {
  POSTGRES
  MYSQL
  SQLITE
  MONGODB
  REDIS
}

enum DatabaseStatus {
  PROVISIONING
  ACTIVE
  PAUSED
  ERROR
}

enum MigrationStatus {
  PENDING
  APPLIED
  FAILED
  REVERTED
}

enum DeploymentStatus {
  PENDING
  QUEUED
  BUILDING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentSource {
  PUSH
  MANUAL
  ROLLBACK
  API
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum LogSource {
  APP
  BUILD
  SYSTEM
  DEPLOY
  GITHUB
}

enum AiSessionStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// ── Sprint 17: Project-level roles ────────────────────────────────────────────

enum ProjectRole {
  owner
  admin
  developer
  operator
  viewer
}

enum ProjectInviteStatus {
  pending
  accepted
  cancelled
  expired
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ToolCallStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum IntegrationType {
  GITHUB
  VERCEL
  RAILWAY
  SUPABASE
  PLANETSCALE
  DATADOG
  NETLIFY
  OTHER
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Owned resources
  ownedWorkspaces      Workspace[]
  workspaceMemberships WorkspaceMember[]
  apiKeys              ApiKey[]

  // Project-scoped relations
  ownedProjects        Project[]        @relation("ProjectOwner")
  assignedFeatures     ProjectFeature[] @relation("FeatureAssignee")
  assignedTasks        ProjectTask[]    @relation("TaskAssignee")
  aiSessions           AiSession[]
  triggeredDeployments Deployment[]
  portfolioItems       PortfolioItem[]  @relation("PortfolioItemCreator")

  // Sprint 17: project team
  projectMemberships  ProjectMember[]
  sentProjectInvites  ProjectInvite[]  @relation("InviteSentBy")
  acceptedInvites     ProjectInvite[]  @relation("InviteAcceptedBy")

  // Sprint 18: audit log
  auditedActions      ProjectAuditEvent[] @relation("AuditActor")
  createdBackups      ProjectBackup[]     @relation("BackupCreatedBy")

  // Sprint 27: operation history
  initiatedOperations ProjectOperation[]
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKSPACE
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  members              WorkspaceMember[]
  projects             Project[]
  integrations         Integration[]
  portfolioItems       PortfolioItem[]
  detectedRepositories    DetectedRepository[]
  ignoredRepositories     IgnoredRepository[]
  githubWebhookDeliveries GitHubWebhookDelivery[]
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKSPACE MEMBER
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceMember {
  id       String   @id @default(cuid())
  role     UserRole @default(MEMBER)
  joinedAt DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  name           String
  slug           String
  description    String?
  type           ProjectType   @default(APP)
  status         ProjectStatus @default(ACTIVE)
  visibility     Visibility    @default(PRIVATE)
  language        String?
  framework       String?
  liveUrl         String?
  lastDeployedAt  DateTime?
  installCommand  String?
  buildCommand    String?
  startCommand    String?
  outputDirectory String?
  lastOpenedAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  // GitHub sync
  githubRepository GitHubRepository?
  commits          GitCommit[]
  syncRuns         GitSyncRun[]

  // Environments, secrets, infra
  environments Environment[]
  domains      Domain[]
  databases    ProjectDatabase[]

  // CI/CD
  deployments Deployment[]
  logs        ProjectLog[]

  // Content
  files    ProjectFile[]
  features ProjectFeature[]
  tasks    ProjectTask[]

  // AI
  aiSessions AiSession[]

  // Portfolio
  portfolioItem PortfolioItem?

  // PM2-based deployment (uploaded/blank/GitHub projects)
  deploymentConfig ProjectDeploymentConfig?

  // Per-project encrypted environment variables
  envVars          ProjectEnvVar[]

  // Database migration records
  dbMigrations     DbMigration[]

  // Sprint 15: per-project alert rules & evaluation history
  alertRules       ProjectAlertRule[]
  alertEvaluations ProjectAlertEvaluation[]

  // Sprint 16: scheduler settings + notification history
  alertSettings       ProjectAlertSettings?
  alertNotifications  ProjectAlertNotification[]

  // Sprint 17: team members + invites
  members             ProjectMember[]
  invites             ProjectInvite[]

  // Sprint 18: audit log
  auditEvents         ProjectAuditEvent[]

  // Sprint 21: backups
  backups             ProjectBackup[]

  // Sprint 23: multi-service deployments
  services            ProjectService[]

  // Sprint 27: operation locking
  operations          ProjectOperation[]

  // Sprint 30: scheduled backups
  backupSchedule      ProjectBackupSchedule?

  // Slug unique within a workspace
  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// GITHUB REPOSITORY  (1:1 with Project — created when a repo is imported)
// ─────────────────────────────────────────────────────────────────────────────

model GitHubRepository {
  id              String    @id @default(cuid())
  githubRepoId    Int       @unique  // GitHub's numeric repo ID
  fullName        String              // "owner/repo"
  name            String
  description     String?
  private         Boolean   @default(false)
  defaultBranch   String    @default("main")
  language        String?
  stargazersCount Int       @default(0)
  url             String              // API URL
  htmlUrl         String              // Browser URL
  cloneUrl        String
  installationId  Int?                // GitHub App installation ID
  latestCommitSha String?             // SHA of the most recent synced commit
  pushedAt        DateTime?
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// GIT COMMIT
// ─────────────────────────────────────────────────────────────────────────────

model GitCommit {
  id           String   @id @default(cuid())
  sha          String
  message      String
  authorName   String
  authorEmail  String
  authoredAt   DateTime
  committedAt  DateTime
  additions    Int      @default(0)
  deletions    Int      @default(0)
  changedFiles Int      @default(0)
  url          String?
  createdAt    DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sha])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// GIT SYNC RUN  (one record per webhook push or manual sync trigger)
// ─────────────────────────────────────────────────────────────────────────────

model GitSyncRun {
  id           String        @id @default(cuid())
  status       GitSyncStatus @default(PENDING)
  source       GitSyncSource @default(WEBHOOK)
  branch       String
  beforeSha    String?
  afterSha     String?
  changedFiles Int           @default(0)
  errorMessage String?
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  createdAt    DateTime      @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DETECTED REPOSITORY
// Repos seen from the GitHub App installation/webhooks, not yet imported.
// ─────────────────────────────────────────────────────────────────────────────

model DetectedRepository {
  id             String   @id @default(cuid())
  githubRepoId   Int
  fullName       String
  name           String
  description    String?
  private        Boolean  @default(false)
  language       String?
  defaultBranch  String   @default("main")
  url            String
  installationId Int?     // GitHub App installation ID (populated by webhooks)
  detectedAt     DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, githubRepoId])
}

// ─────────────────────────────────────────────────────────────────────────────
// IGNORED REPOSITORY
// Repos the user explicitly chose not to import.
// ─────────────────────────────────────────────────────────────────────────────

model IgnoredRepository {
  id           String   @id @default(cuid())
  githubRepoId Int
  fullName     String
  reason       String?
  ignoredAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, githubRepoId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT FILE  (synced from GitHub, used for the in-dashboard editor)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectFile {
  id        String   @id @default(cuid())
  path      String              // Relative path from repo root, e.g. "src/index.ts"
  name      String
  type      FileType @default(FILE)
  size      Int?                // Bytes
  mimeType  String?
  sha       String?             // Git blob SHA for change detection
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT FEATURE  (higher-level feature tracking)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectFeature {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      FeatureStatus @default(PLANNED)
  priority    Priority      @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("FeatureAssignee", fields: [assigneeId], references: [id])

  tasks ProjectTask[]

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT TASK  (granular task, optionally grouped under a feature)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectTask {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  source      TaskSource @default(MANUAL)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  featureId String?
  feature   ProjectFeature? @relation(fields: [featureId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENVIRONMENT  (development / preview / production per project)
// ─────────────────────────────────────────────────────────────────────────────

model Environment {
  id        String            @id @default(cuid())
  name      EnvironmentName   @default(PRODUCTION)
  status    EnvironmentStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  secrets     Secret[]
  deployments Deployment[]
  domains     Domain[]
  databases   ProjectDatabase[]

  // Only one environment of each name per project
  @@unique([projectId, name])
}

// ─────────────────────────────────────────────────────────────────────────────
// SECRET  (env var — encrypted at rest, NEVER store plaintext)
// ─────────────────────────────────────────────────────────────────────────────

model Secret {
  id             String   @id @default(cuid())
  key            String
  encryptedValue String   // AES-256-GCM encrypted — use lib/crypto.ts encrypt()
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, key])
}

// ─────────────────────────────────────────────────────────────────────────────
// DOMAIN
// ─────────────────────────────────────────────────────────────────────────────

model Domain {
  id                String       @id @default(cuid())
  hostname          String       @unique
  isPrimary         Boolean      @default(false)
  status            DomainStatus @default(PENDING)
  sslStatus         SslStatus    @default(NONE)
  verificationToken String?
  verifiedAt        DateTime?
  provider          String?             // e.g. "cloudflare", "route53"
  cnameTarget       String?             // CNAME target for DNS setup
  verificationTxt   String?             // TXT record value
  // Deployment routing fields
  targetPort        Int?                // The PM2 app port this domain proxies to
  nginxConfigPath   String?             // Absolute path to the written nginx .conf file
  lastError         String?             // Last nginx publish error (if any)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT DATABASE
// ─────────────────────────────────────────────────────────────────────────────

model ProjectDatabase {
  id        String         @id @default(cuid())
  name      String
  type      DatabaseType   @default(POSTGRES)
  status    DatabaseStatus @default(PROVISIONING)
  region         String?
  version        String?
  host           String?             // DB host (metadata only — no live connection)
  port           Int?                // DB port
  databaseName   String?             // Database / schema name
  username       String?             // DB user (never store password)
  storageUsedMb  Float?              // Approximate used storage in MB
  storageLimitMb Float?              // Configured storage limit in MB
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id])

  migrations DatabaseMigration[]
}

// ─────────────────────────────────────────────────────────────────────────────
// DATABASE MIGRATION
// ─────────────────────────────────────────────────────────────────────────────

model DatabaseMigration {
  id           String          @id @default(cuid())
  name         String
  status       MigrationStatus @default(PENDING)
  checksum     String?
  appliedAt    DateTime?
  revertedAt   DateTime?
  errorMessage String?
  createdAt    DateTime        @default(now())

  databaseId String
  database   ProjectDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEPLOYMENT
// ─────────────────────────────────────────────────────────────────────────────

model Deployment {
  id            String           @id @default(cuid())
  status        DeploymentStatus @default(PENDING)
  source        DeploymentSource @default(MANUAL)
  url           String?
  branch        String?
  commitSha     String?
  commitMessage String?
  duration      Int?             // milliseconds
  errorMessage  String?
  metadata      Json?
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  createdAt     DateTime         @default(now())
  // Sprint 13: active tracking
  isActive      Boolean          @default(false)
  activatedAt   DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id])

  triggeredById String?
  triggeredBy   User?   @relation(fields: [triggeredById], references: [id])

  logs ProjectLog[]

  @@index([projectId])
  @@index([environmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT LOG
// ─────────────────────────────────────────────────────────────────────────────

model ProjectLog {
  id        String    @id @default(cuid())
  level     LogLevel  @default(INFO)
  source    LogSource @default(APP)
  message   String
  metadata  Json?
  timestamp DateTime  @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  deploymentId String?
  deployment   Deployment? @relation(fields: [deploymentId], references: [id])

  @@index([projectId, timestamp])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI SESSION  (one conversation with the AI assistant per project)
// TODO: Connect to Claude API using lib/claude.ts (not yet implemented)
// ─────────────────────────────────────────────────────────────────────────────

model AiSession {
  id           String          @id @default(cuid())
  title        String?
  status       AiSessionStatus @default(ACTIVE)
  model        String          @default("claude-sonnet-4-6")
  systemPrompt String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  messages AiMessage[]
}

// ─────────────────────────────────────────────────────────────────────────────
// AI MESSAGE
// ─────────────────────────────────────────────────────────────────────────────

model AiMessage {
  id           String   @id @default(cuid())
  role         AiRole
  content      String
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  sessionId String
  session   AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  toolCalls AiToolCall[]

  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI TOOL CALL  (tool use blocks within an assistant message)
// ─────────────────────────────────────────────────────────────────────────────

model AiToolCall {
  id           String         @id @default(cuid())
  name         String
  input        Json
  output       Json?
  status       ToolCallStatus @default(PENDING)
  errorMessage String?
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?

  messageId String
  message   AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATION  (third-party service connections, scoped to a workspace)
// Tokens are encrypted — use lib/crypto.ts encrypt/decrypt before read/write.
// TODO: Implement GitHub App OAuth flow in app/api/integrations/github/
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id               String            @id @default(cuid())
  type             IntegrationType
  status           IntegrationStatus @default(DISCONNECTED)
  encryptedToken   String?           // AES-256-GCM encrypted access token
  externalId       String?           // GitHub user/org ID etc.
  externalUsername String?
  installationId   Int?              // GitHub App installation ID (for GitHub integrations)
  metadata         Json?             // Provider-specific data (scopes, org info, etc.)
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // One integration of each type per workspace
  @@unique([workspaceId, type])
}

// ─────────────────────────────────────────────────────────────────────────────
// API KEY  (programmatic access to the panel's own API)
// Store only the SHA-256 hash — never the raw key.
// ─────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique  // SHA-256(fullKey) — display only the prefix
  prefix     String             // First 8 chars of the key for UI display
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PORTFOLIO ITEM  (public project showcase)
// ─────────────────────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  slug        String   @unique
  tags        String[]
  imageUrl    String?
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("PortfolioItemCreator", fields: [userId], references: [id])

  // Optionally linked to a Project
  projectId String?  @unique
  project   Project? @relation(fields: [projectId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// GITHUB WEBHOOK DELIVERY
// One record per verified incoming webhook delivery — used for the delivery
// history viewer on /integrations/github. The full payload is NOT stored;
// only a safe summary is persisted.
// ─────────────────────────────────────────────────────────────────────────────

model GitHubWebhookDelivery {
  id                 String    @id @default(cuid())
  deliveryId         String?   @unique  // x-github-delivery header (null = missing)
  event              String              // x-github-event header value
  action             String?             // payload.action if present
  repositoryFullName String?             // owner/repo extracted from payload
  installationId     Int?                // payload.installation.id if present
  status             String              // "ok" | "warning" | "error" | "ignored"
  message            String?             // Human-readable outcome summary
  receivedAt         DateTime  @default(now())
  processedAt        DateTime?
  payloadSummary     Json?               // Safe summary — never stores secrets or full payload

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([event, receivedAt])
  @@index([repositoryFullName, receivedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT DEPLOYMENT CONFIG
// PM2-based runtime config for uploaded / blank / GitHub projects.
// One row per project. Port and pm2Name are unique across the table.
// ─────────────────────────────────────────────────────────────────────────────

model ProjectDeploymentConfig {
  id               String   @id @default(cuid())
  projectId        String   @unique
  installCommand   String?
  buildCommand     String?
  startCommand     String
  rootDirectory    String   @default(".")
  outputDirectory  String?
  port             Int      @unique
  pm2Name          String   @unique
  healthPath       String   @default("/")
  nodeEnv          String   @default("production")
  // Route / serving mode
  routeMode        String   @default("fullstack_node") // fullstack_node | static_plus_api | static_only | api_only
  staticOutputDir  String?                              // relative path to built static files (e.g. "dist", "out", ".next/static")
  apiPrefix        String   @default("/api")            // API prefix for static_plus_api mode
  publicStaticPath String?                              // absolute path after static files are published to /var/www
  // Public preview URL (IP-based or subdomain, distinct from custom domains)
  publicPreviewUrl    String?                           // e.g. "http://178.105.105.59/" or "http://178.105.105.59/sardar-security-project/"
  publicPreviewMode   String   @default("disabled")    // "root_ip" | "path_ip" | "preview_subdomain" | "raw_port" | "disabled"
  publicPreviewStatus String   @default("inactive")    // "active" | "inactive" | "error"
  // DB connection test cache (updated by testProjectDatabaseConnectionAction)
  dbConnLastCheckedAt   DateTime?
  dbConnStatus          String?    // "ok" | "failed" | "missing_url"
  dbConnErrorMessage    String?
  dbConnEnvironment     String?
  // Sprint 3: extended deployment config
  runtime          String   @default("node")    // node | static | vite | next | express
  loginPath        String   @default("/login")  // login route used by readiness smoke test
  primaryDomain    String?                       // primary public domain (e.g. sardar-security-project.doorstepmanchester.uk)
  lastValidatedAt  DateTime?
  validationStatus String?   // "valid" | "invalid" | "unchecked"
  validationError  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT ENV VARS  (AES-256-GCM encrypted, per-project, per-environment)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectEnvVar {
  id          String   @id @default(cuid())
  name        String                       // e.g. "DATABASE_URL"
  value       String                       // AES-256-GCM: iv:tag:ciphertext (hex)
  isSecret    Boolean  @default(true)      // If false, value may be shown in UI
  isEnabled   Boolean  @default(true)      // If false, excluded from deployment injection
  environment String   @default("production") // "development" | "preview" | "production"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Sprint 22: Secrets Vault fields
  description   String?                    // human-readable note (never a value)
  required      Boolean  @default(false)   // marks as deployment-critical
  lastRotatedAt DateTime?                  // set whenever value is changed via rotate action
  fingerprint   String?                    // sha256(plaintext).slice(0,12) — safe to display
  source        String   @default("manual") // "manual" | "import" | "template" | "deployment" | "system"

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name, environment])
}

// ─────────────────────────────────────────────────────────────────────────────
// DATABASE MIGRATION  (pg_dump → pg_restore records)
// ─────────────────────────────────────────────────────────────────────────────

model DbMigration {
  id          String    @id @default(cuid())
  status      String    @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  dumpPath    String?                        // absolute path to the dump file
  logs        String?                        // masked output from pg_dump / pg_restore
  wipedTarget Boolean   @default(false)      // whether DROP SCHEMA was run first
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT ALERT RULES  (Sprint 15)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectAlertRule {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name     String
  type     String  // AlertRuleType string
  severity String  @default("warning")  // "info" | "warning" | "critical"
  enabled  Boolean @default(true)

  /// JSON config for thresholds/options (e.g. memoryMbThreshold, restartCountThreshold)
  config Json?

  lastCheckedAt   DateTime?
  lastStatus      String?   // "ok" | "triggered" | "unknown" | "disabled"
  lastMessage     String?
  lastTriggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, enabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT ALERT EVALUATION  (Sprint 15 — manual evaluation history)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectAlertEvaluation {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  ruleId   String?
  ruleName String?
  type     String
  severity String
  status   String  // "ok" | "triggered" | "unknown" | "disabled"
  message  String

  /// Full monitoring snapshot (JSON) — optional, only stored for triggered results
  snapshot Json?

  /// Sprint 16: "manual" | "scheduled" | "manual_scheduler_test"
  source             String  @default("manual")
  notificationStatus String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, source])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT ALERT SETTINGS  (Sprint 16 — per-project scheduler + delivery config)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectAlertSettings {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  schedulerEnabled      Boolean  @default(false)
  intervalMinutes       Int      @default(15)

  /// "log_only" | "email_dry_run" | "email"
  deliveryMode          String   @default("log_only")
  notificationEmail     String?
  notifyOnRecovery      Boolean  @default(true)
  repeatCooldownMinutes Int      @default(60)

  lastRunAt              DateTime?
  nextRunAt              DateTime?
  lastStatus             String?   // "ok" | "triggered" | "error"
  lastTriggeredCount     Int       @default(0)
  lastNotificationStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schedulerEnabled])
  @@index([nextRunAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT ALERT NOTIFICATION  (Sprint 16 — notification attempt log)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectAlertNotification {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// "log" | "email"
  channel         String  @default("log")
  /// "log_only" | "email_dry_run" | "email"
  deliveryMode    String
  /// "log_only" | "dry_run_sent" | "sent" | "suppressed_cooldown" | "failed" | "unavailable" | "no_alerts"
  status          String
  recipientMasked String?           // e.g. "s***@example.com"
  subject         String?
  messagePreview  String?           // first 500 chars
  triggeredCount  Int     @default(0)
  /// "scheduled" | "manual_scheduler_test" | "test"
  source          String  @default("scheduled")
  error           String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT MEMBER  (Sprint 17 — project-level RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectMember {
  id        String      @id @default(cuid())
  role      ProjectRole @default(viewer)
  joinedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT INVITE  (Sprint 17 — invite-link flow)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectInvite {
  id        String              @id @default(cuid())
  /// Secure random token included in the invite link
  token     String              @unique
  /// Email address the invite was sent to — masked in all API responses
  email     String
  role      ProjectRole         @default(viewer)
  status    ProjectInviteStatus @default(pending)
  expiresAt DateTime
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("InviteSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  acceptedById String?
  acceptedBy   User?  @relation("InviteAcceptedBy", fields: [acceptedById], references: [id])

  @@index([projectId])
  @@index([token])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT AUDIT EVENT  (Sprint 18 — append-only audit log)
//
// Records who did what, when, from where, and whether it succeeded.
// Append-only for Sprint 18 — no delete or update operations allowed.
// Values (env var values, tokens, DB rows, terminal output) are NEVER stored.
// ─────────────────────────────────────────────────────────────────────────────

model ProjectAuditEvent {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// The user who performed the action (null for anonymous/system events)
  actorUserId String?
  actorUser   User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  /// Denormalised actor fields so events remain readable if the user is deleted
  actorEmail String?
  actorName  String?
  actorRole  String?

  /// Dot-namespaced action label, e.g. "team.invite.created", "env.created"
  action   String
  /// Broad category, e.g. "team", "env", "terminal", "deploy"
  category String
  /// "success" | "failed" | "denied" | "skipped"
  result   String @default("success")

  /// What the action targeted (optional)
  targetType  String?
  targetId    String?
  targetLabel String?

  /// One-line human-readable description of the event
  summary  String
  /// Sanitised key/value metadata — never contains secret values
  metadata Json?

  /// Best-effort network metadata (from x-forwarded-for / x-real-ip / user-agent)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, category])
  @@index([projectId, action])
  @@index([projectId, result])
  @@index([actorUserId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT BACKUP  (Sprint 21 — project-scoped snapshots + restore)
//
// Archives are stored at:
//   storage/backups/<slug>/<backupRef>/backup.zip
//   storage/backups/<slug>/<backupRef>/manifest.json
//
// includesSecrets is always false in Sprint 21 — no plaintext secret values
// are written to archives.  includesEnvKeys stores key names only (redacted).
// ─────────────────────────────────────────────────────────────────────────────

model ProjectBackup {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Stable unique ref used in file paths and audit events, e.g. bkp_20260621_153000_abcd1234
  backupRef String @unique

  /// Human-readable label supplied by the user (optional)
  label String?

  /// creating | ready | failed | restoring | restored | deleted
  status String @default("creating")

  /// manual | pre_restore | system
  backupType String @default("manual")

  /// Relative path from project storage root, e.g. backups/<slug>/<backupRef>
  storagePath String

  /// Archive filename inside storagePath, e.g. backup.zip
  archiveName String @default("backup.zip")

  /// Compressed archive size in bytes (null while creating)
  sizeBytes Int?

  /// Number of files included in the archive
  fileCount Int?

  /// SHA-256 hex of the archive file
  checksumSha256 String?

  includesSource  Boolean @default(true)
  includesConfig  Boolean @default(true)
  includesEnvKeys Boolean @default(true)
  includesSecrets Boolean @default(false)

  /// Id of the user who triggered the backup (null for system/automatic backups)
  createdByUserId String?
  createdBy       User?   @relation("BackupCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  deletedAt   DateTime?

  restoreCount   Int       @default(0)
  lastRestoredAt DateTime?

  /// Safe error message (no stack trace) set on failure
  lastError String?

  /// Arbitrary key/value metadata stored at backup creation time
  metadataJson Json?

  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT SERVICE  (Sprint 23: multi-service / monorepo deployment config)
//
// One project may have zero or many ProjectService records.
//   - Zero records  → use existing single-service ProjectDeploymentConfig path
//   - One+ records  → use multi-service deployment runner
//
// Service types:
//   node   → PM2-managed Node.js process (API, SSR, worker)
//   static → Static files built and served by nginx (React/Vite SPA etc.)
// ─────────────────────────────────────────────────────────────────────────────

model ProjectService {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Human-readable display name (e.g. "API Server", "Web Frontend")
  name        String
  /// URL-safe slug used in PM2 names and paths (e.g. "api", "web")
  slug        String
  /// "node" | "static"
  serviceType String

  /// Working directory relative to the release root (default ".")
  workingDir String @default(".")
  /// "pnpm" | "npm" | "yarn"
  packageManager String?
  installCommand String?
  buildCommand   String?
  /// Node services only: command to start the process
  startCommand String?

  /// Node services: which port this process listens on (4100–4999 range)
  internalPort Int?
  /// Node services: health check endpoint path (e.g. "/api/healthz")
  healthPath String?

  /// Static services: relative path from release root to built output (e.g. "dist/public")
  staticOutputDir String?
  /// Static services: if true, 404s fall back to index.html for SPA routing
  spaFallback Boolean @default(false)

  /// Which deployment environment this service belongs to
  envName String @default("production")
  /// If true, this is the primary public-facing service (used for /api routing decisions)
  isPrimary Boolean @default(false)
  /// If false, this service is excluded from deployments
  isEnabled Boolean @default(true)

  /// Optional JSON array of required env key names (e.g. ["DATABASE_URL","SESSION_SECRET"])
  requiredEnvKeysJson String?

  /// Deployment tracking (updated after each multi-service deploy)
  lastDeploymentRef String?
  lastStatus        String?    // "success" | "failed" | "building" | null
  lastError         String?
  lastDeployedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, slug])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT OPERATION  (Sprint 27: DB-backed operation locking)
// ─────────────────────────────────────────────────────────────────────────────
//
// Tracks long-running project operations (deploy, backup, restore, patch apply)
// so that conflicting concurrent operations are blocked.
//
// Lifecycle:
//   created → running (same insert) → success | failed | cancelled | stale
//
// Stale detection: a cron/cleanup call marks rows as "stale" when
//   updatedAt < now - STALE_THRESHOLD (per operationType).
// ─────────────────────────────────────────────────────────────────────────────

model ProjectOperation {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Machine-readable operation type — drives the compatibility matrix
  operationType String   // "deploy" | "multi_service_deploy" | "backup_create" | "backup_restore" | "backup_delete" | "patch_apply"

  /// Human-readable title shown in the banner and history list
  title         String

  /// Current status
  status        String   @default("running")  // "running" | "success" | "failed" | "cancelled" | "stale"

  /// The user who initiated the operation (null for system-initiated)
  initiatedByUserId String?
  initiatedBy       User?    @relation(fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  /// Service ID involved (multi-service deploys, single-service ops)
  serviceId     String?

  /// Operation-specific metadata (no secret values)
  meta          Json?

  /// Last error message if status is "failed"
  lastError     String?

  /// Timestamps
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([projectId, status])
  @@index([projectId, operationType, status])
  @@index([updatedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT BACKUP SCHEDULE  (Sprint 30: scheduled backups + retention)
//
// One schedule per project.  The scheduler checks enabled rows where
// nextRunAt <= now and fires createProjectBackup with backupType="scheduled".
// ─────────────────────────────────────────────────────────────────────────────

model ProjectBackupSchedule {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  enabled   Boolean @default(false)

  /// "daily" | "weekly"
  frequency   String @default("daily")

  /// HH:mm in server local time, e.g. "02:00"
  timeOfDay   String @default("02:00")

  /// 0=Sun … 6=Sat; required when frequency="weekly"
  dayOfWeek   Int?

  /// How many successful scheduled backups to keep; older ones are deleted
  retentionCount Int @default(7)

  /// What to include in the archive
  includeSource      Boolean @default(true)
  includeEnvMetadata Boolean @default(true)

  /// Timestamps set by the scheduler
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  lastFailureAt   DateTime?
  lastFailureText String?
  nextRunAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, nextRunAt])
}
