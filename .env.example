# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/prisom_panel"

# ─── App URL ───────────────────────────────────────────────────────────────────
# IMPORTANT: Set this to your tunnel URL (e.g. ngrok / Cloudflare) during local
# testing — the GitHub webhook URL is derived from this value. After changing it,
# restart the server and update the Webhook URL in your GitHub App settings.
# See docs/github-app-local-testing.md for full setup instructions.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── GitHub App  (create at https://github.com/settings/apps) ─────────────────
# Used for webhook delivery and repo-level API access (preferred over OAuth).
# All five variables are required for full functionality.
GITHUB_APP_ID=""

# PEM private key — paste the ENTIRE key as a SINGLE LINE with literal \n
# characters replacing newlines. Use double quotes in .env to allow \n escapes.
# Example conversion (macOS / Linux):
#   awk 'NF{printf "%s\\n", $0}' ~/Downloads/your-app.private-key.pem
# Then wrap the output in double quotes:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY=""

# Random secret you entered in GitHub App → Webhook Secret.
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=""

# ─── GitHub OAuth  (for user-facing "Sign in with GitHub" flow) ───────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Auth ─────────────────────────────────────────────────────────────────────
# SESSION_SECRET is used to sign the HTTP-only session cookie.
# Generate with: openssl rand -hex 32
# Falls back to NEXTAUTH_SECRET if not set.
SESSION_SECRET=""

# Admin credentials for the project panel login page (/login).
# In development, if these are missing the fallback is:
#   email: admin@prisom.dev | password: PrisomAdmin@123!
PROJECT_PANEL_ADMIN_EMAIL=""
PROJECT_PANEL_ADMIN_PASSWORD=""

NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Encryption  (AES-256-GCM key for secrets/tokens stored in DB) ────────────
# Generate with: openssl rand -base64 32
# NEVER commit a real key — rotate immediately if exposed.
ENCRYPTION_KEY=""

# ─── Development only ──────────────────────────────────────────────────────────
# Skip webhook signature verification for local testing WITHOUT a tunnel.
# NEVER set this to true in production — it completely disables a security control.
# When true, any unsigned HTTP POST to /api/webhooks/github will be accepted.
# Ignored unless NODE_ENV !== "production".
GITHUB_WEBHOOK_DEV_BYPASS=false
